---
const requirements = [
  'WordPress 6.9+',
  'PHP 8.2+',
  'Modern browser with WebGPU (Chrome 113+, Edge 113+)',
  'Pretty permalinks enabled',
];

const steps = [
  { num: '1', text: 'Upload and activate the plugin' },
  { num: '2', text: 'Click WP Agentic Admin in the admin menu' },
  { num: '3', text: 'Wait for the one-time model download' },
  { num: '4', text: 'Type your first question: "check my site health"' },
];
---

<section id="get-started" class="py-20 md:py-32">
  <div class="section-container">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20">
      <!-- Requirements -->
      <div class="reveal">
        <p class="text-sm font-medium text-indigo-400 mb-3 tracking-wide uppercase">Requirements</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-100 tracking-tight mb-6">
          What you need
        </h2>
        <div class="space-y-3">
          {requirements.map((req) => (
            <div class="flex items-center gap-3">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>
              <span class="text-sm text-slate-400">{req}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Get Started -->
      <div class="reveal">
        <p class="text-sm font-medium text-indigo-400 mb-3 tracking-wide uppercase">Quick Start</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-100 tracking-tight mb-6">
          Get started in 60 seconds
        </h2>
        <div class="space-y-5">
          {steps.map((step, i) => (
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center shrink-0 mt-0.5">
                <span class="text-xs font-bold text-indigo-400">{step.num}</span>
              </div>
              <div>
                <p class="text-sm text-slate-300 leading-relaxed">{step.text}</p>
                {i === steps.length - 1 && (
                  <p class="text-xs text-slate-600 mt-1">That's it. Your private AI admin is ready.</p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
