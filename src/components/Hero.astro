---
const base = import.meta.env.BASE_URL;
const videos = [
  { src: 'videos/content-writer.mp4', label: 'AI Content Writer' },
  { src: 'videos/plugin-abilities.mp4', label: 'Plugin Abilities' },
  { src: 'videos/voice-notes-have-i-been-hacked.mp4', label: 'Voice Security Check' },
];
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 hero-bg"></div>
  <div class="absolute inset-0 hero-grid"></div>

  <div class="section-container relative z-10 py-20 md:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium text-indigo-300 border border-indigo-500/20 bg-indigo-500/5 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          100% Local AI &mdash; Zero Cloud Dependencies
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.08] mb-6">
          <span class="text-slate-100">Your Private AI</span><br />
          <span class="text-slate-100">Admin for </span><span class="gradient-text-accent">WordPress</span>
        </h1>

        <p class="text-lg text-slate-400 leading-relaxed max-w-lg mb-10">
          The first AI-powered site assistant that runs entirely in your browser. No cloud. No API keys. No data ever leaves your device.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="https://playground.wordpress.net/?blueprint-url=https://raw.githubusercontent.com/pluginslab/wp-agentic-admin/main/.playground/blueprint.json" target="_blank" rel="noopener" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Try in Playground
          </a>
          <a href="https://github.com/pluginslab/wp-agentic-admin" target="_blank" rel="noopener" class="btn-secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            View on GitHub
          </a>
        </div>

        <a href="https://hackathon.cloudfest.com/" target="_blank" rel="noopener" class="hackathon-badge mt-8 flex items-center gap-3 hover:opacity-80 transition-opacity">
          <img src={`${base}images/cf-hackathon.png`} alt="CloudFest Hackathon" width="120" height="auto" class="hackathon-logo-small" />
          <span class="text-sm text-slate-500">Built during CloudFest Hackathon 2026</span>
        </a>
      </div>

      <!-- Stats Badge -->
      <a href={`${base}stats/`} class="stats-badge" aria-label="View hackathon stats: 257 commits in 3 days">
        <span class="stats-badge-number">257</span>
        <span class="stats-badge-label">commits<br/>in 3 days</span>
      </a>

      <!-- Video Showcase -->
      <div class="hero-video-wrapper" id="hero-video-deck">
        <div class="hero-video-deck">
          {videos.map((video, i) => (
            <div
              class={`video-card ${i === 0 ? 'card-front' : i === 1 ? 'card-middle' : 'card-back'}`}
              data-index={i}
              data-label={video.label}
            >
              <video
                src={`${import.meta.env.BASE_URL}${video.src}`}
                muted
                playsinline
                preload={i === 0 ? 'auto' : 'metadata'}
                aria-label={`Demo: ${video.label}`}
              />
            </div>
          ))}
        </div>

        <!-- Controls -->
        <div class="video-controls">
          <div class="video-dots" role="tablist" aria-label="Video demos">
            {videos.map((video, i) => (
              <button
                class={`video-dot ${i === 0 ? 'active' : ''}`}
                data-dot={i}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-label={video.label}
              />
            ))}
          </div>
          <span class="video-label" id="video-label">{videos[0].label}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-bg {
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(99, 102, 241, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(139, 92, 246, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(99, 102, 241, 0.05) 0%, transparent 50%);
  }

  .hero-grid {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 30%, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 30%, black 0%, transparent 70%);
  }

  /* Video deck */
  .hero-video-wrapper {
    perspective: 1200px;
  }

  .hero-video-deck {
    position: relative;
    aspect-ratio: 3 / 2;
    transform: rotateY(-6deg) rotateX(2deg);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-video-deck:hover {
    transform: rotateY(-2deg) rotateX(1deg) translateY(-4px);
  }

  /* Cards */
  .video-card {
    position: absolute;
    inset: 0;
    border-radius: 10px;
    overflow: hidden;
    background: #0d1117;
    cursor: pointer;
    transition:
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .video-card video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #0d1117;
  }

  /* Card states */
  .card-front {
    z-index: 3;
    transform: translate(0, 0) scale(1);
    opacity: 1;
    box-shadow:
      0 0 0 1px rgba(99, 102, 241, 0.15),
      0 20px 60px -12px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(99, 102, 241, 0.1);
  }

  .card-middle {
    z-index: 2;
    transform: translate(14px, 10px) scale(0.95);
    opacity: 0.5;
    box-shadow:
      0 0 0 1px rgba(99, 102, 241, 0.08),
      0 12px 40px -8px rgba(0, 0, 0, 0.4);
  }

  .card-back {
    z-index: 1;
    transform: translate(28px, 20px) scale(0.9);
    opacity: 0.25;
    box-shadow:
      0 0 0 1px rgba(99, 102, 241, 0.04),
      0 8px 24px -6px rgba(0, 0, 0, 0.3);
  }

  /* Controls */
  .video-controls {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 20px;
    padding-left: 4px;
  }

  .video-dots {
    display: flex;
    gap: 6px;
  }

  .video-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(148, 163, 184, 0.25);
    cursor: pointer;
    padding: 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .video-dot:hover {
    background: rgba(148, 163, 184, 0.5);
  }

  .video-dot.active {
    background: rgba(99, 102, 241, 0.8);
    box-shadow: 0 0 8px rgba(99, 102, 241, 0.4);
    width: 20px;
    border-radius: 4px;
  }

  .video-label {
    font-size: 0.8rem;
    color: rgba(148, 163, 184, 0.5);
    letter-spacing: 0.02em;
    transition: opacity 0.3s ease;
  }

  /* Hackathon logo */
  .hackathon-logo-small {
    height: auto;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  .hackathon-logo-small:hover {
    opacity: 0.9;
  }

  /* Stats Badge */
  .stats-badge {
    position: absolute;
    top: 7rem;
    right: 2rem;
    z-index: 20;
    width: 116px;
    height: 116px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #7c3aed);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: white;
    box-shadow:
      0 0 0 3px rgba(139, 92, 246, 0.3),
      0 0 24px rgba(99, 102, 241, 0.3),
      0 8px 32px rgba(0, 0, 0, 0.4);
    animation: badge-float 3s ease-in-out infinite, badge-glow 2s ease-in-out infinite;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .stats-badge:hover {
    transform: scale(1.1);
    animation-play-state: paused;
  }

  .stats-badge-number {
    font-size: 1.7rem;
    font-weight: 800;
    line-height: 1;
    font-family: 'JetBrains Mono', monospace;
  }

  .stats-badge-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.25;
    text-align: center;
    opacity: 0.85;
    margin-top: 2px;
  }

  @keyframes badge-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-7px); }
  }

  @keyframes badge-glow {
    0%, 100% {
      box-shadow:
        0 0 0 3px rgba(139, 92, 246, 0.25),
        0 0 20px rgba(99, 102, 241, 0.2),
        0 8px 32px rgba(0, 0, 0, 0.4);
    }
    50% {
      box-shadow:
        0 0 0 4px rgba(139, 92, 246, 0.5),
        0 0 40px rgba(99, 102, 241, 0.45),
        0 8px 32px rgba(0, 0, 0, 0.4);
    }
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .stats-badge {
      position: relative;
      top: auto;
      right: auto;
      margin: 1.5rem auto 0;
      width: 96px;
      height: 96px;
    }
    .stats-badge-number {
      font-size: 1.4rem;
    }
    .stats-badge-label {
      font-size: 0.55rem;
    }
    .hero-video-deck {
      transform: none;
    }
    .hero-video-deck:hover {
      transform: translateY(-4px);
    }
    .card-middle {
      transform: translate(8px, 6px) scale(0.96);
    }
    .card-back {
      transform: translate(16px, 12px) scale(0.92);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .video-card {
      transition: none;
    }
    .hero-video-deck {
      transition: none;
    }
    .video-dot {
      transition: none;
    }
    .stats-badge {
      animation: none;
    }
  }
</style>

<script>
  const deck = document.getElementById('hero-video-deck');
  if (deck) {
    const cards = deck.querySelectorAll<HTMLDivElement>('.video-card');
    const videoEls = deck.querySelectorAll<HTMLVideoElement>('.video-card video');
    const dots = deck.querySelectorAll<HTMLButtonElement>('.video-dot');
    const label = document.getElementById('video-label');
    const states = ['card-front', 'card-middle', 'card-back'];
    let current = 0;
    let isVisible = false;

    function setActive(index: number) {
      current = index;
      cards.forEach((card, i) => {
        const offset = (i - current + cards.length) % cards.length;
        card.className = `video-card ${states[offset]}`;
      });

      // Play/pause videos — reset non-active ones to start
      videoEls.forEach((vid, i) => {
        if (i === current && isVisible) {
          vid.currentTime = 0;
          vid.play().catch(() => {});
        } else {
          vid.pause();
          vid.currentTime = 0;
        }
      });

      // Update dots
      dots.forEach((dot, i) => {
        const isActive = i === current;
        dot.classList.toggle('active', isActive);
        dot.setAttribute('aria-selected', String(isActive));
      });

      // Update label
      if (label) {
        const newLabel = cards[current]?.dataset.label || '';
        label.style.opacity = '0';
        setTimeout(() => {
          label.textContent = newLabel;
          label.style.opacity = '1';
        }, 150);
      }
    }

    function advance() {
      setActive((current + 1) % cards.length);
    }

    // When a video ends, advance to the next one
    videoEls.forEach((vid, i) => {
      vid.addEventListener('ended', () => {
        if (i === current) {
          advance();
        }
      });
    });

    // Click cards to advance
    cards.forEach((card) => {
      card.addEventListener('click', () => {
        advance();
      });
    });

    // Click dots to go to specific video
    dots.forEach((dot, i) => {
      dot.addEventListener('click', (e) => {
        e.stopPropagation();
        setActive(i);
      });
    });

    // IntersectionObserver — only play when visible
    const observer = new IntersectionObserver(
      ([entry]) => {
        isVisible = entry.isIntersecting;
        if (isVisible) {
          videoEls[current]?.play().catch(() => {});
        } else {
          videoEls.forEach((v) => v.pause());
        }
      },
      { threshold: 0.3 }
    );
    observer.observe(deck);

    // Pause when tab hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        videoEls.forEach((v) => v.pause());
      } else if (isVisible) {
        videoEls[current]?.play().catch(() => {});
      }
    });
  }
</script>
