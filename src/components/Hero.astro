---
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 hero-bg"></div>
  <div class="absolute inset-0 hero-grid"></div>

  <div class="section-container relative z-10 py-20 md:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium text-indigo-300 border border-indigo-500/20 bg-indigo-500/5 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          100% Local AI &mdash; Zero Cloud Dependencies
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.08] mb-6">
          <span class="text-slate-100">Your Private AI</span><br />
          <span class="text-slate-100">Admin for </span><span class="gradient-text-accent">WordPress</span>
        </h1>

        <p class="text-lg text-slate-400 leading-relaxed max-w-lg mb-10">
          The first AI-powered site assistant that runs entirely in your browser. No cloud. No API keys. No data ever leaves your device.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="https://playground.wordpress.net/?blueprint-url=https://raw.githubusercontent.com/pluginslab/wp-agentic-admin/main/.playground/blueprint.json" target="_blank" rel="noopener" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Try in Playground
          </a>
          <a href="https://github.com/pluginslab/wp-agentic-admin" target="_blank" rel="noopener" class="btn-secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            View on GitHub
          </a>
        </div>

        <a href="https://hackathon.cloudfest.com/" target="_blank" rel="noopener" class="hackathon-badge mt-8 flex items-center gap-3 hover:opacity-80 transition-opacity">
          <img src="/images/cf-hackathon.png" alt="CloudFest Hackathon" width="120" height="auto" class="hackathon-logo-small" />
          <span class="text-sm text-slate-500">Built during CloudFest Hackathon 2026</span>
        </a>
      </div>

      <!-- Hero Screenshot -->
      <div class="hero-screenshot-wrapper">
        <div class="hero-screenshot">
          <img
            src="/images/chat-window.png"
            alt="WP Agentic Admin chat interface showing AI assistant with tool categories"
            width="800"
            height="600"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-bg {
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(99, 102, 241, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(139, 92, 246, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(99, 102, 241, 0.05) 0%, transparent 50%);
  }

  .hero-grid {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 30%, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 30%, black 0%, transparent 70%);
  }

  .hero-screenshot-wrapper {
    perspective: 1200px;
  }

  .hero-screenshot {
    transform: rotateY(-6deg) rotateX(2deg);
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(99, 102, 241, 0.15),
      0 20px 60px -12px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(99, 102, 241, 0.1);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-screenshot:hover {
    transform: rotateY(-2deg) rotateX(1deg) translateY(-4px);
    box-shadow:
      0 0 0 1px rgba(99, 102, 241, 0.25),
      0 30px 80px -12px rgba(0, 0, 0, 0.6),
      0 0 60px rgba(99, 102, 241, 0.15);
  }

  .hero-screenshot img {
    display: block;
    width: 100%;
    height: auto;
  }

  .hackathon-logo-small {
    height: auto;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  .hackathon-logo-small:hover {
    opacity: 0.9;
  }

  @media (max-width: 1023px) {
    .hero-screenshot {
      transform: none;
    }
    .hero-screenshot:hover {
      transform: translateY(-4px);
    }
  }
</style>
